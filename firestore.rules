
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Admins: Any logged-in user can read the list to check their own status. Only super admins can change it.
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role == 'Super Admin';
    }

    // Profiles: Users can read/write their own profile. Authenticated users can list profiles (for total user count).
    match /profiles/{userId} {
      allow read, write: if request.auth.uid == userId;
      allow list: if request.auth != null;
    }

    // Products: Anyone can read. Admins can write.
    match /products/{productId} {
      allow read: if true;
      allow write: if get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role in ['Super Admin', 'Products Admin', 'Normal Admin'];
    }

    // Deleted Products Log: Only admins can read/write.
    match /deletedProductsLog/{logId} {
      allow read, write: if get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role in ['Super Admin', 'Products Admin', 'Normal Admin'];
    }

    // Reviews: Anyone can read approved reviews. Logged-in users can create. Admins can write/delete.
    match /reviews/{reviewId} {
      allow read: if resource.data.isApproved == true || get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role in ['Super Admin', 'Website Admin'];
      allow list: if get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role in ['Super Admin', 'Website Admin'];
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role in ['Super Admin', 'Website Admin'];
    }

    // Orders: Users can create and read their own. Admins can read all and update status.
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth.uid == resource.data.userId || get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role != null;
      allow list, update: if get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role != null;
    }

    // Deal Submissions: Admins can read/write.
    match /dealSubmissions/{submissionId} {
      allow read, write: if get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role != null;
    }

    // Delivery Routes: Anyone can read. Super Admins can write.
    match /deliveryRoutes/{routeId} {
        allow read: if true;
        allow write: if get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role == 'Super Admin';
    }
  }
}
