
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to products
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow public read access to reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Secure access to user profiles
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow admins to manage deal submissions
    match /dealSubmissions/{submissionId} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to create orders
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null; // Simplified for now
    }
    
    // Log for deleted products
    match /deletedProductsLog/{logId} {
        allow read, create: if request.auth != null;
    }
    
    // Allow public read for delivery routes, write for admins
    match /deliveryRoutes/{routeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
