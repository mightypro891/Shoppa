
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access to products, reviews, and routes
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Writes should be done via server-side functions
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null; // Only logged-in users can create reviews
      allow update, delete: if false; // Only admins (via server-side) can update/delete
    }

    match /deliveryRoutes/{routeId} {
        allow read: if true;
        allow write: if false; // Only admins (via server-side) can manage routes
    }
    
    // Secure user profiles
    match /profiles/{userId} {
      allow read, update: if request.auth.uid == userId; // Users can only access their own profile
      allow create: if request.auth.uid == userId;
    }

    // Secure orders
    match /orders/{orderId} {
      allow read: if request.auth.uid == resource.data.userId; // Users can only read their own orders
      allow create: if request.auth.uid == request.resource.data.userId; // Users can only create orders for themselves
      allow update, delete: if false; // Order updates are handled server-side by admins
    }

    // Secure other admin-only collections
    match /deletedProductsLog/{logId} {
      allow read, write: if false;
    }

    match /dealSubmissions/{submissionId} {
      allow read, write: if false;
    }
  }
}
