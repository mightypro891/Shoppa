
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- DEFAULT RULES ---
    // By default, deny all reads and writes.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PUBLIC-READ COLLECTIONS ---
    // Products, reviews, and routes can be read by anyone.
    match /products/{productId} {
      allow read: if true;
      // Allow only admins to write. We'll check the custom claim.
      allow write: if request.auth.token.isAdmin == true;
    }
    
    match /deletedProductsLog/{logId} {
        allow read, write: if request.auth.token.isAdmin == true;
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.isApproved == true;
      allow create: if request.auth != null; // Any logged-in user can create a review
      // Only admins can approve or delete reviews
      allow update, delete: if request.auth.token.isAdmin == true;
    }
    
    match /dealSubmissions/{submissionId} {
        allow read, write: if request.auth.token.isAdmin == true;
    }

    match /deliveryRoutes/{routeId} {
        allow read: if true;
        allow write: if request.auth.token.isAdmin == true;
    }
    
    // Admins list can be read by any authenticated user to determine roles.
    match /admins/{adminId} {
      allow read: if request.auth != null;
      // Only super admins can change the admin list.
      allow write: if request.auth.token.isSuperAdmin == true;
    }

    // --- USER-SPECIFIC DATA ---
    // Users can manage their own profile.
    // Authenticated users can read all profiles for counting purposes.
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Users can create orders for themselves.
    // Users can only read their own orders.
    match /orders/{orderId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read, update: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.token.isAdmin == true);
    }
  }
}
