
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin
    function isAdmin() {
      // In a real app, this would be a lookup in an 'admins' collection
      // For this prototype, we check a hardcoded list in AuthContext, 
      // but security rules can't access that. This rule is a placeholder.
      // We will rely on client-side checks for admin actions for now.
      return request.auth != null; 
    }

    // Products can be read by anyone, but only modified by admins
    match /products/{productId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    
    // Deleted products log can only be written to and read by admins
    match /deletedProductsLog/{logId} {
      allow read, write: if isAdmin();
    }
    
    // Deal submissions can be created by admins, but only read by them
     match /dealSubmissions/{submissionId} {
      allow read, write: if isAdmin();
    }

    // Delivery routes can be read by anyone, but only managed by admins
    match /deliveryRoutes/{routeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews can be read by anyone
    // Users can create reviews, but cannot update or delete them
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false; // Or check if user is admin
    }
    
    // User profiles can only be read and updated by the owner of the profile
    match /profiles/{userId} {
      allow read, update, create: if request.auth != null && request.auth.uid == userId;
    }
    
    // Orders can be created by authenticated users
    // Orders can only be read by the user who created them or an admin
    // Admins can update orders (e.g., status)
    match /orders/{orderId} {
       allow create: if request.auth != null;
       allow read: if (request.auth != null && request.auth.uid == resource.data.userId) || isAdmin();
       allow update: if isAdmin();
       allow delete: if false; // Do not allow orders to be deleted
    }

    // Default deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
